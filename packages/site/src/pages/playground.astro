---
import StarlightPage from "@astrojs/starlight/components/StarlightPage.astro";
import { EditorWrapper } from "~/components/EditorWrapper";
---

<div class="pg-container">
	<StarlightPage
		frontmatter={{
			title: "Playground",
			template: "splash",
		}}
	/>
	<div class="editor">
		<EditorWrapper client:only="react" />
	</div>
</div>

<style is:global>
	body {
		padding: 0;
		margin: 0;
	}
	.page {
		min-height: 0;
	}
	.main-pane {
		display: none;
	}
	.editor {
		position: relative;
		height: 100px;
	}
</style>
